          "expr": "sum(rate(agentic_harness_agent_tokens_input_sum{agent_name=~\"$agent_name\"}[5m])) by (agent_name)",
          "legendFormat": "{{agent_name}} input",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(agentic_harness_agent_tokens_output_sum{agent_name=~\"$agent_name\"}[5m])) by (agent_name)",
