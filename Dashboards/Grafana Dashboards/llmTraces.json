          },
          "expr": "sum(increase(agentic_harness_agent_tokens_cost_estimated_USD_total{agent_name=~\"$agent_name\"}[1h])) by (agent_name)",
          "legendFormat": "{{agent_name}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
