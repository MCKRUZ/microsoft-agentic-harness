          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 11,
      "type": "bargauge",
      "title": "Tokens per Turn",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 14 },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "agentic_harness_agent_tokens_tokens_per_turn_sum{agent_name=~\"$agent_name\"} / agentic_harness_agent_tokens_tokens_per_turn_count{agent_name=~\"$agent_name\"}",
          "legendFormat": "{{agent_name}}",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "displayMode": "gradient",
        "orientation": "horizontal",
        "showUnfilled": true,
        "minVizWidth": 8,
        "minVizHeight": 16,
        "valueMode": "text"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2000 },
              { "color": "red", "value": 5000 }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      }
    },
    {
      "type": "row",
      "title": "Tool Performance",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 12,
      "type": "table",
      "title": "Tool Performance",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 21 },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "A",
          "expr": "sum(increase(agentic_harness_agent_tool_invocations_total{agent_name=~\"$agent_name\"}[24h])) by (tool_name)",
          "legendFormat": "",
          "instant": true,
          "format": "table"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "B",
          "expr": "sum(increase(agentic_harness_agent_tool_errors_total{agent_name=~\"$agent_name\"}[24h])) by (tool_name)",
          "legendFormat": "",
          "instant": true,
          "format": "table"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "C",
          "expr": "sum(agentic_harness_agent_tool_duration_seconds_sum{agent_name=~\"$agent_name\"}) by (tool_name) / sum(agentic_harness_agent_tool_duration_seconds_count{agent_name=~\"$agent_name\"}) by (tool_name)",
          "legendFormat": "",
          "instant": true,
          "format": "table"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "D",
          "expr": "sum(increase(agentic_harness_agent_tool_errors_total{agent_name=~\"$agent_name\"}[24h])) by (tool_name) / sum(increase(agentic_harness_agent_tool_invocations_total{agent_name=~\"$agent_name\"}[24h])) by (tool_name)",
          "legendFormat": "",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "renameByName": {
              "tool_name": "Tool",
              "Value #A": "Invocations (24h)",
              "Value #B": "Errors (24h)",
              "Value #C": "Avg Duration (s)",
              "Value #D": "Error Rate"
            },
            "indexByName": {
              "tool_name": 0,
              "Value #A": 1,
              "Value #B": 2,
              "Value #C": 3,
              "Value #D": 4
            }
          }
        }
      ],
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "Invocations (24h)",
            "desc": true
          }
        ],
        "footer": {
          "show": false
        }
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Invocations (24h)" },
            "properties": [
              { "id": "decimals", "value": 0 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Errors (24h)" },
            "properties": [
              { "id": "decimals", "value": 0 },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "red", "value": 1 }
                  ]
                }
              },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } },
              { "id": "color", "value": { "mode": "thresholds" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Avg Duration (s)" },
            "properties": [
              { "id": "unit", "value": "s" },
              { "id": "decimals", "value": 3 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Error Rate" },
            "properties": [
              { "id": "unit", "value": "percentunit" },
              { "id": "decimals", "value": 2 },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 0.05 },
                    { "color": "red", "value": 0.1 }
                  ]
                }
              },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } },
              { "id": "color", "value": { "mode": "thresholds" } }
            ]
          }
        ]
      }
    }
  ]
}