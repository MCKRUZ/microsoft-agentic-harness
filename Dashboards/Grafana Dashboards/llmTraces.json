          },
          "expr": "sum(increase(agentic_harness_agent_tokens_output_sum{agent_name=~\"$agent_name\"}[24h]))",
          "legendFormat": "Output Tokens",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "super-light-blue"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "super-light-blue", "value": null }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Total Cost",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 4, "w": 5, "x": 15, "y": 0 },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(agentic_harness_agent_tokens_cost_estimated_USD_total{agent_name=~\"$agent_name\"}[24h]))",
          "legendFormat": "Cost",
