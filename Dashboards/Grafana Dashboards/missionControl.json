{
  "uid": "agentic-harness-mission-control",
  "title": "Mission Control",
  "description": "Executive command center — system health at a glance",
  "tags": ["agentic-harness", "overview"],
  "editable": true,
  "graphTooltip": 1,
  "refresh": "10s",
  "schemaVersion": 39,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "templating": {
    "list": [
      {
        "name": "agent_name",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(agent_name)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "sort": 1,
        "label": "Agent"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Active Conversations",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(agentic_harness_agent_orchestration_conversation_duration_count{agent_name=~\"$agent_name\"}) - sum(agentic_harness_agent_orchestration_conversation_duration_count{agent_name=~\"$agent_name\"} offset 5m)",
          "legendFormat": "Active",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "id": 2,
      "title": "Token Burn Rate",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(agentic_harness_agent_tokens_total_sum{agent_name=~\"$agent_name\"}[$__rate_interval]))",
          "legendFormat": "Tokens/s",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "custom": {
            "axisSoftMin": 0
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "id": 3,
      "title": "Cost Rate",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(agentic_harness_agent_tokens_cost_estimated_total{agent_name=~\"$agent_name\"}[$__rate_interval])) * 3600",
          "legendFormat": "$/hr",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": {
            "mode": "fixed",
            "fixedColor": "purple"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "purple", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "id": 4,
      "title": "Error Rate",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(agentic_harness_agent_tool_errors_total{agent_name=~\"$agent_name\"}[$__rate_interval])) / sum(rate(agentic_harness_agent_tool_invocations_total{agent_name=~\"$agent_name\"}[$__rate_interval]))",
          "legendFormat": "Error %",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.02 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "id": 5,
      "title": "Cache Hit Rate",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(agentic_harness_agent_tokens_cache_hit_rate_sum{agent_name=~\"$agent_name\"}) / sum(agentic_harness_agent_tokens_cache_hit_rate_count{agent_name=~\"$agent_name\"})",
          "legendFormat": "Hit Rate",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.8 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "id": 6,
      "title": "Safety Block Rate",
      "type": "stat",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(agentic_harness_agent_safety_blocks_total{agent_name=~\"$agent_name\"}[$__rate_interval])) / sum(rate(agentic_harness_agent_safety_evaluations_total{agent_name=~\"$agent_name\"}[$__rate_interval]))",
          "legendFormat": "Block %",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 3,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "id": 7,
      "title": "Conversation Activity",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 5, "w": 10, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(agentic_harness_agent_orchestration_conversation_duration_count{agent_name=~\"$agent_name\"}[$__rate_interval]))",
          "legendFormat": "Conversations"
        },
        {
          "refId": "B",
          "expr": "sum(rate(agentic_harness_agent_orchestration_tool_call_count_total{agent_name=~\"$agent_name\"}[$__rate_interval]))",
          "legendFormat": "Tool Calls"
        },
        {
          "refId": "C",
          "expr": "sum(rate(agentic_harness_agent_safety_evaluations_total{agent_name=~\"$agent_name\"}[$__rate_interval]))",
          "legendFormat": "Safety Checks"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "gradientMode": "none",
            "spanNulls": false
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Conversations" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "cyan" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Tool Calls" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Safety Checks" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }
      }
    },
    {
      "id": 8,
      "title": "Cumulative Cost Today",
      "type": "timeseries",
      "gridPos": { "x": 10, "y": 5, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(agentic_harness_agent_tokens_cost_estimated_total{agent_name=~\"$agent_name\"}[$__rate_interval]))",
          "legendFormat": "Cost"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "axisPlacement": "auto",
            "spanNulls": false
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }
      }
    },
    {
      "id": 9,
      "title": "Service Health",
      "type": "stat",
      "gridPos": { "x": 18, "y": 5, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "count(count by (agent_name) (agentic_harness_agent_orchestration_conversation_duration_count))",
          "legendFormat": "Agents Active",
          "instant": true
        },
        {
          "refId": "B",
          "expr": "count(count by (mcp_server_name) (agentic_harness_mcp_server_requests_total))",
          "legendFormat": "MCP Servers",
          "instant": true
        },
        {
          "refId": "C",
          "expr": "count(count by (agent_tool_name) (agentic_harness_agent_tool_invocations_total))",
          "legendFormat": "Tools",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value_and_name",
        "wideLayout": true,
        "justifyMode": "auto"
      }
    },
    {
      "id": 10,
      "title": "Tool Duration P50/P95",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 14, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.5, sum(rate(agentic_harness_agent_tool_duration_bucket{agent_name=~\"$agent_name\"}[$__rate_interval])) by (le))",
          "legendFormat": "P50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum(rate(agentic_harness_agent_tool_duration_bucket{agent_name=~\"$agent_name\"}[$__rate_interval])) by (le))",
          "legendFormat": "P95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "axisPlacement": "auto",
            "gradientMode": "none",
            "spanNulls": false
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }
      }
    },
    {
      "id": 11,
      "title": "Token Usage",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 14, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(agentic_harness_agent_tokens_input_sum{agent_name=~\"$agent_name\"}[$__rate_interval]))",
          "legendFormat": "Input"
        },
        {
          "refId": "B",
          "expr": "sum(rate(agentic_harness_agent_tokens_output_sum{agent_name=~\"$agent_name\"}[$__rate_interval]))",
          "legendFormat": "Output"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 30,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "axisPlacement": "auto",
            "gradientMode": "none",
            "spanNulls": false
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }
      }
    },
    {
      "id": 12,
      "title": "Safety Outcomes",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 14, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(agentic_harness_agent_safety_evaluations_total{agent_name=~\"$agent_name\"}[$__rate_interval])) by (agent_safety_outcome)",
          "legendFormat": "{{agent_safety_outcome}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "axisPlacement": "auto",
            "gradientMode": "none",
            "spanNulls": false
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "pass" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "block" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "redact" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }
      }
    },
    {
      "id": 13,
      "title": "Context Budget Utilization",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 23, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "avg(agentic_harness_agent_context_budget_utilization_sum{agent_name=~\"$agent_name\"} / agentic_harness_agent_context_budget_utilization_count{agent_name=~\"$agent_name\"})",
          "legendFormat": "Budget Used",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "orientation": "auto"
      }
    },
    {
      "id": 14,
      "title": "Cost by Model",
      "type": "piechart",
      "gridPos": { "x": 8, "y": 23, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(agentic_harness_agent_tokens_cost_estimated_total{agent_name=~\"$agent_name\"}) by (gen_ai_request_model)",
          "legendFormat": "{{gen_ai_request_model}}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "pieType": "donut",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "right", "calcs": [] },
        "displayLabels": ["percent"]
      }
    },
    {
      "id": 15,
      "title": "Cache Savings",
      "type": "stat",
      "gridPos": { "x": 16, "y": 23, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(agentic_harness_agent_tokens_cost_estimated_total{agent_name=~\"$agent_name\"})",
          "legendFormat": "Total Cost",
          "instant": true
        },
        {
          "refId": "B",
          "expr": "sum(agentic_harness_agent_tokens_cost_cache_savings_total{agent_name=~\"$agent_name\"})",
          "legendFormat": "Cache Savings",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": {
            "mode": "palette-classic"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name",
        "justifyMode": "auto",
        "wideLayout": true,
        "orientation": "horizontal"
      }
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "weekStart": ""
}