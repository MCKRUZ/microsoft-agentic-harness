          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(agentic_harness_agent_orchestration_turns_per_conversation_bucket[$__rate_interval])) by (le))",
          "refId": "B",
          "legendFormat": "p95"
        }
