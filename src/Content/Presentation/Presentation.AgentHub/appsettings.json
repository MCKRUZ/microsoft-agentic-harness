{
  "Auth": {
    "Disabled": false
  },
  "AzureAd": {
    "TenantId": "PLACEHOLDER — set via user-secrets in development",
    "ClientId": "PLACEHOLDER — set via user-secrets in development",
    "Audience": "PLACEHOLDER — api://{apiClientId}"
  },
  "AppConfig": {
    "Infrastructure": {
      "FileSystem": {
        "AllowedBasePaths": [ "../../../../../../.." ]
      }
    },
    "AI": {
      "AgentFramework": {
        "DefaultDeployment": "gpt-4o",
        "ClientType": "AzureOpenAI"
      },
      "Skills": {
        "BasePath": "skills",
        "AdditionalPaths": []
      },
      "Agents": {
        "BasePath": "agents",
        "AdditionalPaths": []
      }
    },
    "AgentHub": {
      "ConversationsPath": "./conversations",
      "DefaultAgentName": "",
      "MaxHistoryMessages": 20,
      "Cors": {
        "AllowedOrigins": []
      }
    },
    "Logging": {
      "PipeName": "AgenticHarnessLogs",
      "LogsBasePath": "logs",
      "EnableStructuredJson": true
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Http":  { "Url": "http://*:50772" },
      "Https": { "Url": "https://*:50771" }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Information",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.AspNetCore.Hosting.Diagnostics": "Information",
      "System": "Warning"
    }
  }
}
