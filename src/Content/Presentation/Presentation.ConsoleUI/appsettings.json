{
  "AppConfig": {
    "Common": {
      "SlowThresholdSec": 5
    },
    "Logging": {
      "LogsBasePath": "logs",
      "PipeName": "AgenticHarnessLogs"
    },
    "Agent": {
      "MaxTurnsPerConversation": 10,
      "DefaultTokenBudget": 128000
    },
    "AI": {
      "AgentFramework": {
        "DefaultDeployment": "gpt-4o",
        "ClientType": "AzureOpenAI"
      },
      "Skills": {
        "BasePath": "skills",
        "AdditionalPaths": []
      }
    },
    "Observability": {
      "EnableTracing": true,
      "EnableMetrics": true,
      "SamplingRatio": 1.0
    },
    "Cache": {
      "CacheType": "Memory"
    }
  }
}
