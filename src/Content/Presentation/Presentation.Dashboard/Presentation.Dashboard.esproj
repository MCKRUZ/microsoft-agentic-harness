<Project Sdk="Microsoft.VisualStudio.JavaScript.Sdk">
  <ItemGroup Label="ProjectConfigurations">
    <ProjectConfiguration Include="Debug-AgentHub-All|AnyCPU">
      <Configuration>Debug-AgentHub-All</Configuration>
      <Platform>AnyCPU</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Debug-AgentHub-Dashboard|AnyCPU">
      <Configuration>Debug-AgentHub-Dashboard</Configuration>
      <Platform>AnyCPU</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Debug-AgentHub-WebUI|AnyCPU">
      <Configuration>Debug-AgentHub-WebUI</Configuration>
      <Platform>AnyCPU</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Debug|AnyCPU">
      <Configuration>Debug</Configuration>
      <Platform>AnyCPU</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|AnyCPU">
      <Configuration>Release</Configuration>
      <Platform>AnyCPU</Platform>
    </ProjectConfiguration>
  </ItemGroup>
  <PropertyGroup>
    <StartupCommand>npm run dev</StartupCommand>
    <StartupUrl>http://localhost:5174</StartupUrl>
    <JavaScriptTestFramework>Vitest</JavaScriptTestFramework>
    <DeployOnBuild>false</DeployOnBuild>
  </PropertyGroup>
</Project>